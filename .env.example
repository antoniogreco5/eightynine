# ─── Database (Vercel Postgres) ─────────────────────────
POSTGRES_PRISMA_URL="your-vercel-postgres-url"
POSTGRES_URL_NON_POOLING="your-vercel-postgres-direct-url"

# ─── NextAuth ────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"

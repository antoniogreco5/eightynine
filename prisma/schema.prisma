generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ─── NextAuth Required Models ─────────────────────────────────────────────────

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  holdings      Holding[]
  watchlist     WatchlistItem[]
  snapshots     Snapshot[]
  sharedReports SharedReport[]
  createdAt     DateTime        @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Portfolio Data ───────────────────────────────────────────────────────────

model Holding {
  id           String   @id @default(cuid())
  userId       String
  ticker       String
  shares       Float
  avgCost      Float
  currentPrice Float    @default(0)
  sector       String
  notes        String   @default("")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

// ─── Watchlist ────────────────────────────────────────────────────────────────

model WatchlistItem {
  id           String   @id @default(cuid())
  userId       String
  ticker       String
  sector       String
  targetShares Float    @default(0)
  targetAmount Float    @default(0)
  currentPrice Float    @default(0)
  notes        String   @default("")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([userId])
}

// ─── Portfolio Snapshots (daily diversification tracking) ─────────────────────

model Snapshot {
  id                 String   @id @default(cuid())
  userId             String
  totalValue         Float
  holdingCount       Int
  violationCount     Int
  concentrationScore Int
  topHolding         String
  topHoldingWeight   Float
  topSector          String
  topSectorWeight    Float
  holdingsData       String   @db.Text
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())

  @@index([userId])
}

// ─── Shared Reports ───────────────────────────────────────────────────────────

model SharedReport {
  id             String   @id @default(cuid())
  userId         String
  shareToken     String   @unique
  portfolioData  String   @db.Text
  expiresAt      DateTime
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([shareToken])
}
